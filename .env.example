# anime-play 配置：复制为 .env 后按需修改
#   cp .env.example .env
# 优先级：真实环境变量 > .env 文件 > 默认值

# ===== 必填 =====
# OpenList 地址
OPENLIST_BASE_URL=http://192.168.1.10:5244
# OpenList 管理员 token（管理页「其他设置」获取）
OPENLIST_TOKEN=alist-xxxxxxxxxxxxxxxx
# 扫描的根路径，多个用逗号分隔
SCAN_ROOTS=/anime,/anime2

# ===== 可选（注释掉则用默认值）=====
# 服务监听端口
#LISTEN_PORT=8080
# 映射文件路径（容器内路径，需位于挂载 volume 内）
#MAPPING_FILE=/data/mapping.json
# 目录索引自动刷新间隔
#REFRESH_INTERVAL=30m
# 视频直链缓存 TTL，应保守地小于 OpenList 签名有效期
#RAWURL_CACHE_TTL=1h
